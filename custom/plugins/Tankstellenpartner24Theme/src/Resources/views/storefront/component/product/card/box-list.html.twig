{# =====================================================================
   Tankstellenpartner24Theme — Kategori/listing LISTE satırı (B2B hızlı sipariş):
   [görsel] [marka+isim+kısa açıklama+yıldız] [fiyat] [Menge -/+] [Warenkorb]
   Tek satırda — müşteri tak tak tak hızlı sipariş verir.
   ===================================================================== #}
{% block component_product_box %}
    {% if product %}
        {% set id = product.id %}
        {% set name = product.translated.name %}
        {% set brand = product.manufacturer.translated.name|default('') %}
        {% set cover = product.cover.media %}
        {% set real = product.calculatedPrice %}
        {% if product.calculatedPrices.count > 0 %}
            {# Staffelpreis: İLK kademe (en düşük miktar = 1 adet) gösterilir →
               sepete eklenince ödenecek GERÇEK fiyatla tutarlı. Eskiden .last
               (en büyük miktar = en ucuz) gösteriliyordu, sepet farklı çıkıyordu (bug). #}
            {% set real = product.calculatedPrices.first %}
        {% endif %}
        {% set displayFrom = product.calculatedPrices.count > 1 %}
        {% set isAvailable = not product.isCloseout or (product.stock >= product.minPurchase) %}
        {# Varyantlı ürün (childCount>0) listeden eklenemez → Details. Fiyat kademesi (displayFrom) eklenebilir. #}
        {% set canBuy = isAvailable and product.childCount <= 0 %}
        {% set detailUrl = seoUrl('frontend.detail.page', { productId: id }) %}
        {# VITRINEN-PRODUKT (Mike): Custom-Field "Produkt Ersatz Url" gefüllt →
           nicht kaufbar, Klick (Foto+Name) auf externe URL, kein Preis, "Zum Anbieter".
           Custom-Field-Name zentral: falls Mikes technischer Name abweicht, NUR hier ändern. #}
        {% set vaporExtUrl = product.translated.customFields.external_product_link|default(product.customFields.external_product_link|default(null)) %}
        {# Foto/Name-Ziel: Vitrine → externe URL, sonst Detailseite #}
        {% set rowTarget = vaporExtUrl ?: detailUrl %}
        {# B2B: Preise & Warenkorb für eingeloggte Kunden ODER Vertriebler (Agent).
           Mike-Regel: auch context.extension(vioAgent) prüfen. #}
        {% set vaporLoggedIn = context.customer or context.extension('vioAgent') %}

        <div class="card product-box vapor-listrow{% if vaporExtUrl %} vapor-listrow--ext{% endif %}"
             data-product-information="{{ {id, name, brand}|json_encode }}"
             {% if not vaporExtUrl and canBuy and config('core.listing.allowBuyInListing') %}data-vapor-cart-row data-product-id="{{ id }}"{% endif %}>
            <div class="vapor-listrow__inner">

                {# --- Görsel --- (Vitrine → externe URL, neuer Tab) #}
                <a href="{{ rowTarget }}" class="vapor-listrow__media" title="{{ name }}"{% if vaporExtUrl %} target="_blank" rel="noopener noreferrer"{% endif %}>
                    {% if cover.url %}
                        {% sw_thumbnails 'vapor-listrow-img' with {
                            media: cover,
                            sizes: { default: '120px' },
                            attributes: { class: 'vapor-listrow__img', alt: (cover.translated.alt ?: name), loading: 'lazy' }
                        } %}
                    {% else %}
                        <span class="vapor-listrow__placeholder">{% sw_icon 'placeholder' style { size: 'fluid' } %}</span>
                    {% endif %}
                </a>

                {# --- Bilgi: marka + isim + açıklama + yıldız --- #}
                <div class="vapor-listrow__info">
                    {% if brand %}<span class="vapor-listrow__brand">{{ brand }}</span>{% endif %}
                    <a href="{{ rowTarget }}" class="vapor-listrow__name" title="{{ name }}"{% if vaporExtUrl %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ name }}</a>
                    {# NUR echte Bewertungen, keine Fake-Sterne (Wunsch Ahmet/Mike) #}
                    {% if product.ratingAverage > 0 %}
                        <div class="vapor-listrow__stars">
                            {% sw_include '@Storefront/storefront/component/review/rating.html.twig' with { points: product.ratingAverage } %}
                        </div>
                    {% endif %}
                    <p class="vapor-listrow__desc">{{ product.translated.description|striptags|slice(0, 130) }}</p>
                </div>

                {# --- Fiyat --- (Vitrine → kein Preis; sonst B2B: nur eingeloggt) #}
                <div class="vapor-listrow__price">
                    {% if vaporExtUrl %}
                        {# Vitrine: kein Preis (Mike) #}
                    {% elseif vaporLoggedIn %}
                        {% if displayFrom %}<span class="vapor-listrow__from">{{ 'listing.listingTextFrom'|trans|sw_sanitize }}</span>{% endif %}
                        <span class="vapor-listrow__amount">{{ real.unitPrice|currency }}</span>
                        <span class="vapor-listrow__tax">{{ context.taxState == 'gross' ? 'inkl. MwSt.' : 'zzgl. MwSt.' }}</span>
                    {% else %}
                        <span class="vapor-listrow__login-price">{% sw_icon 'lock-closed' %} Preise nach Login</span>
                    {% endif %}
                </div>

                {# --- Menge stepper = CANLI SEPET (+ ekler / − çıkarır) --- (B2B-gated) #}
                <div class="vapor-listrow__buy">
                    {% if vaporExtUrl %}
                        {# Vitrine: kein Warenkorb → "Zum Anbieter" (externe URL, neuer Tab) #}
                        <a href="{{ vaporExtUrl }}" class="btn vapor-listrow__cart vapor-listrow__cart--ext" target="_blank" rel="noopener noreferrer">
                            Anfragen
                        </a>
                    {% elseif not vaporLoggedIn %}
                        {# Nicht eingeloggt → Login-CTA statt Preis/Warenkorb #}
                        <a href="{{ path('frontend.account.login.page') }}" class="btn vapor-listrow__cart is-login">
                            {% sw_icon 'avatar' %} Anmelden
                        </a>
                    {% elseif canBuy and config('core.listing.allowBuyInListing') %}
                        {# +/− doğrudan sepete yazar (JS: initLiveCart). Adet 0 = sepette değil. #}
                        <div class="vapor-qty vapor-qty--live"
                             data-vapor-cartqty
                             data-product-id="{{ id }}"
                             data-min="{{ product.minPurchase ?: 1 }}"
                             data-step="{{ product.purchaseSteps ?: 1 }}"
                             {% if product.maxPurchase %}data-max="{{ product.maxPurchase }}"{% endif %}>
                            <button type="button" class="vapor-qty__btn" data-cartqty="minus" aria-label="weniger">−</button>
                            <input class="vapor-qty__input" type="number" value="0" min="0" inputmode="numeric"
                                   aria-label="Menge im Warenkorb">
                            <button type="button" class="vapor-qty__btn" data-cartqty="plus" aria-label="mehr">+</button>
                        </div>
                    {% else %}
                        <a href="{{ detailUrl }}" class="btn vapor-listrow__cart is-detail">
                            {{ 'listing.boxProductDetails'|trans|sw_sanitize }}
                        </a>
                    {% endif %}
                </div>

            </div>
        </div>
    {% endif %}
{% endblock %}
