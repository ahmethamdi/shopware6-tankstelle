{% sw_extends '@Storefront/storefront/component/product/card/box-standard.html.twig' %}

{# =====================================================================
   Tankstellenpartner24Theme — Ürün kartı (mockup birebir):
   "Beliebt" rozeti + wishlist kalbi üstte → görsel → marka+başlık →
   yıldız rating → fiyat (sol) + yuvarlak "+" sepete-ekle butonu (sağ).
   Açıklama metni KALDIRILDI.

   VITRINEN-PRODUKTE (Mike): Wenn das Custom-Field "Produkt Ersatz Url"
   (external_product_link) gefüllt ist → Produkt ist NICHT kaufbar:
   - Foto + Name verlinken auf die externe URL (neuer Tab), NICHT auf Detailseite
   - Preis wird ausgeblendet
   - Statt Warenkorb-Button: "Zum Anbieter"-Button
   ===================================================================== #}

{# Custom-Field-Name zentral. Falls Mikes technischer Name abweicht, NUR hier ändern. #}
{% set vaporExtUrl = product.translated.customFields.external_product_link|default(product.customFields.external_product_link|default(null)) %}

{# "Beliebt" rozeti — kartın sol üstüne (18+ yaş rozeti akaryakıt B2B'de kaldırıldı) #}
{% block component_product_box_badges %}
    <span class="vapor-card-badge">Beliebt</span>
    {{ parent() }}
{% endblock %}

{# Foto-Link: Bei Vitrinen-Produkt → externe URL statt Detailseite.
   Core legt den Bild-Link über die "stretched-link" am Namen. Wir überschreiben
   den Namen-Block, damit der gesamte Karten-Klick (Foto inkl.) auf die externe URL geht. #}
{% block component_product_box_name %}
    {% if vaporExtUrl %}
        {% if headlineLevel is not empty %}
            {{ "<h#{headlineLevel} class=\"#{headlineClasses}\">"|raw }}
                <a href="{{ vaporExtUrl }}" title="{{ name }}" target="_blank" rel="noopener noreferrer"
                   class="product-name stretched-link vapor-ext-name">{{ name }}</a>
            {{ "</h#{headlineLevel}>"|raw }}
        {% else %}
            <a href="{{ vaporExtUrl }}" title="{{ name }}" target="_blank" rel="noopener noreferrer"
               class="product-name stretched-link vapor-ext-name">{{ name }}</a>
        {% endif %}
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{# Açıklama metnini gizle (mockup'ta yok) #}
{% block component_product_box_description %}{% endblock %}

{# Preis: Vitrinen-Produkt → komplett ausblenden (Mike: "preis kannst du auch ausblenden").
   Sonst B2B-Logik: Preise sichtbar für eingeloggte Kunden ODER Vertriebler (Agent). #}
{% block component_product_box_price %}
    {% if vaporExtUrl %}
        {# Vitrine: kein Preis #}
    {% elseif context.customer or context.extension('vioAgent') %}
        {{ parent() }}
    {% else %}
        <div class="product-price-info vapor-card-loginprice">
            <span class="vapor-card-loginprice__txt">{% sw_icon 'lock-closed' %} Preise nach Login</span>
        </div>
    {% endif %}
{% endblock %}

{# Action: Vitrinen-Produkt → "Zum Anbieter" statt Warenkorb. Sonst normal. #}
{% block component_product_box_action %}
    {% if vaporExtUrl %}
        <div class="vapor-add-wrap vapor-ext-wrap">
            <a href="{{ vaporExtUrl }}" class="btn vapor-ext-btn" target="_blank" rel="noopener noreferrer">
                Anfragen
            </a>
        </div>
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{# Varyant karakteristiği de gizli (mockup sade) #}
{% block component_product_box_variant_characteristics %}{% endblock %}

{# Rating: NUR echte Shopware-Bewertungen. Keine Fake-Sterne mehr.
   Ohne echte ratingAverage wird NICHTS angezeigt (Wunsch Ahmet/Mike). #}
{% block component_product_box_rating %}
    {% if product.ratingAverage > 0 %}
        <div class="product-rating vapor-card-stars">
            {% sw_include '@Storefront/storefront/component/review/rating.html.twig' with {
                points: product.ratingAverage,
                style: 'text-primary'
            } %}
        </div>
    {% endif %}
{% endblock %}
