{% sw_extends '@Storefront/storefront/component/buy-widget/buy-widget.html.twig' %}

{# =====================================================================
   Tankstellenpartner24Theme — Ürün detay satın alma kutusu modernizasyonu.
   B2B: Preise (auch Staffelpreis-Tabelle) + Warenkorb nur eingeloggt.
   Satın alma formundan SONRA: USP güven rozetleri (kargo/iade/ödeme).
   ===================================================================== #}

{# B2B: Preise sichtbar für eingeloggte Kunden ODER Vertriebler (Agent).
   Mike-Regel: nicht nur context.customer, auch context.extension(vioAgent) prüfen. #}
{% set vaporCanSeePrices = context.customer or context.extension('vioAgent') %}

{# VITRINEN-PRODUKT (Mike): Falls jemand doch direkt auf die Detailseite kommt,
   ist das Produkt nicht kaufbar → kein Preis/Warenkorb, nur "Zum Anbieter".
   Custom-Field-Name zentral: bei Abweichung NUR hier ändern. #}
{% set vaporExtUrl = product.translated.customFields.external_product_link|default(product.customFields.external_product_link|default(null)) %}

{# B2B: Fiyat tablosu (Staffelpreise) + tax + reviews girişsizken GİZLE.
   Vitrine → Preis komplett aus. #}
{% block buy_widget_price %}
    {% if vaporExtUrl %}
        {# Vitrine: kein Preis #}
    {% elseif vaporCanSeePrices %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{# Reviews KOMPLETT ausgeblendet (Wunsch Ahmet/Mike): keine Sterne, keine Zahl,
   kein Review-Link im Buy-Widget. Leerer Block überschreibt den Core-Block. #}
{% block buy_widget_reviews %}{% endblock %}
{% block buy_widget_buy_form %}
    {# Vitrine (Mike): nicht kaufbar → nur "Zum Anbieter"-Button, kein Warenkorb #}
    {% if vaporExtUrl %}
        <div class="vapor-buybox-ext">
            <a href="{{ vaporExtUrl }}" class="btn vapor-buybox-ext__btn" target="_blank" rel="noopener noreferrer">
                Anfragen
            </a>
        </div>
    {# B2B: Preise & Warenkorb für eingeloggte Kunden ODER Vertriebler #}
    {% elseif vaporCanSeePrices %}
        {{ parent() }}
    {% else %}
        {# Nicht eingeloggt → Login-Gate statt Preis/Warenkorb #}
        <div class="vapor-buybox-login">
            <span class="vapor-buybox-login__ico">{% sw_icon 'lock-closed' %}</span>
            <span class="vapor-buybox-login__title">Großhandelspreise nach Login</span>
            <span class="vapor-buybox-login__text">Preise und Bestellung sind ausschließlich für registrierte Fachhändler sichtbar.</span>
            <div class="vapor-buybox-login__actions">
                <a href="{{ path('frontend.account.login.page') }}" class="btn vapor-buybox-login__btn is-primary">{% sw_icon 'avatar' %} Anmelden</a>
                <a href="{{ path('frontend.account.register.page') }}" class="btn vapor-buybox-login__btn is-ghost">Händler werden</a>
            </div>
        </div>
    {% endif %}

    {% if product.active %}
        <ul class="vapor-buybox-usp">
            {% for usp in [
                { i: 'truck', t: 'Kostenloser Versand ab 500 € Netto' },
                { i: 'lock-closed', t: 'Sichere Bezahlung · PayPal & Rechnung' },
                { i: 'rocket', t: 'Schnelle Lieferung · 24–48h Versand' },
                { i: 'marketing', t: 'B2B-Großhandelspreise nach Login' }
            ] %}
                <li class="vapor-buybox-usp__item">
                    <span class="vapor-buybox-usp__ico">{% sw_icon usp.i %}</span>
                    <span>{{ usp.t }}</span>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
