{% sw_extends '@Storefront/storefront/layout/header/header.html.twig' %}

{# =====================================================================
   Tankstellenpartner24Theme — Header (REDESIGN, modern B2B/kurumsal):
   [1] Koyu lacivert USP üst şeridi (top-bar.html.twig)
   [2] Ana header: logo solda | ortada geniş AÇIK arama | sağda aksiyonlar + CTA
   [3] Menü şeridi (mega menü tetikleyici) — logonun altında ayrı satır
   ===================================================================== #}
{% block layout_header_navigation %}
    <div class="tp-header">

        {# ============ [2] ANA HEADER SATIRI ============ #}
        <div class="tp-header__main">
            <div class="tp-header__inner">

                {# Mobil hamburger #}
                {% block vapor_header_mobile_toggle %}
                    <button class="tp-header__burger d-lg-none"
                            type="button"
                            data-off-canvas-menu="true"
                            aria-label="{{ 'general.menuLink'|trans|striptags }}">
                        {% sw_icon 'stack' %}
                    </button>
                {% endblock %}

                {# Logo #}
                {% block layout_header_logo %}
                    <div class="tp-header__logo">
                        {% sw_include '@Storefront/storefront/layout/header/logo.html.twig' %}
                    </div>
                {% endblock %}

                {# Ortada geniş AÇIK arama çubuğu (desktop) #}
                {% block layout_header_search %}
                    <div class="tp-header__search d-none d-lg-flex">
                        {% sw_include '@Storefront/storefront/layout/header/search.html.twig' %}
                    </div>
                {% endblock %}

                {# Sağ aksiyonlar #}
                {% block layout_header_actions %}
                    <div class="tp-header__actions">

                        {# Mobil arama ikonu #}
                        {% block vapor_header_search_icon %}
                            <button class="tp-action d-lg-none search-toggle-btn js-search-toggle-btn collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#searchCollapse"
                                    aria-expanded="false"
                                    aria-controls="searchCollapse"
                                    aria-label="{{ 'header.searchButton'|trans|striptags }}">
                                {% sw_icon 'search' %}
                            </button>
                        {% endblock %}

                        {# Hesap #}
                        {% block layout_header_actions_account %}
                            <div class="tp-action tp-action--account account-menu">
                                {% sw_include '@Storefront/storefront/layout/header/actions/account-widget.html.twig' %}
                            </div>
                        {% endblock %}

                        {# Sepet #}
                        {% set offcanvasCartOptions = { autoFocus: true } %}
                        {% block layout_header_actions_cart %}
                            <div class="tp-action tp-action--cart header-cart"
                                 data-off-canvas-cart="true"
                                 data-off-canvas-cart-options="{{ offcanvasCartOptions|json_encode }}">
                                <a class="tp-action__link header-cart-btn"
                                   href="{{ path('frontend.checkout.cart.page') }}"
                                   data-cart-widget="true"
                                   title="{{ 'checkout.cartTitle'|trans|striptags }}">
                                    {% sw_include '@Storefront/storefront/layout/header/actions/cart-widget.html.twig' %}
                                </a>
                            </div>
                        {% endblock %}

                        {# B2B kayıt CTA #}
                        {% block vapor_header_cta %}
                            <a href="{{ path('frontend.account.register.page') }}" class="tp-header__cta d-none d-lg-inline-flex">
                                {% sw_icon 'avatar' %}
                                <span>Jetzt registrieren</span>
                            </a>
                        {% endblock %}
                    </div>
                {% endblock %}
            </div>
        </div>

        {# ============ [3] MENÜ ŞERİDİ (mega menü tetikleyici) ============ #}
        {% block vapor_header_menu %}
            {% set vaporManualMenu = [] %}
            {% for i in 1..6 %}
                {% set mName = theme_config('vapor-header-menu-' ~ i ~ '-name') %}
                {% set mLink = theme_config('vapor-header-menu-' ~ i ~ '-link') %}
                {% if mName %}
                    {% set vaporManualMenu = vaporManualMenu|merge([{ name: mName, link: mLink }]) %}
                {% endif %}
            {% endfor %}
            {% set vaporNavTree = page.header.navigation.tree|default([]) %}
            <div class="tp-navbar d-none d-lg-block">
                <div class="tp-navbar__inner">
                    <nav class="tp-navbar__nav">
                        <a class="tp-navbar__link tp-navbar__link--home" href="{{ path('frontend.home.page') }}">
                            {% sw_icon 'house' %} Home
                        </a>
                        {% if vaporManualMenu|length > 0 %}
                            {% for m in vaporManualMenu %}
                                <a class="tp-navbar__link" href="{{ m.link ?: '#' }}">{{ m.name }}</a>
                            {% endfor %}
                        {% else %}
                            {# Fallback: Shopware Hauptnavigation + mega menü panel (hover) #}
                            {% for m in vaporNavTree %}
                                {% set hasChildren = m.children|default([])|length > 0 %}
                                <div class="tp-navbar__item{% if hasChildren %} has-mega{% endif %}">
                                    <a class="tp-navbar__link" href="{{ seoUrl('frontend.navigation.page', { navigationId: m.category.id }) }}">
                                        {{ m.category.translated.name }}
                                        {% if hasChildren %}<span class="tp-navbar__caret" aria-hidden="true">▾</span>{% endif %}
                                    </a>
                                    {% if hasChildren %}
                                        <div class="tp-mega">
                                            <div class="tp-mega__inner">
                                                {% for child in m.children %}
                                                    <div class="tp-mega__col">
                                                        <a class="tp-mega__head" href="{{ seoUrl('frontend.navigation.page', { navigationId: child.category.id }) }}">
                                                            {{ child.category.translated.name }}
                                                        </a>
                                                        {% if child.children|default([])|length > 0 %}
                                                            <ul class="tp-mega__list">
                                                                {% for gc in child.children|slice(0, 8) %}
                                                                    <li>
                                                                        <a class="tp-mega__link" href="{{ seoUrl('frontend.navigation.page', { navigationId: gc.category.id }) }}">
                                                                            {{ gc.category.translated.name }}
                                                                        </a>
                                                                    </li>
                                                                {% endfor %}
                                                            </ul>
                                                        {% endif %}
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        {% endif %}
                    </nav>

                    {# Sağda ödeme logoları (panelden) #}
                    {% block vapor_header_payments %}
                        {% set headerPays = [
                            theme_config('vapor-header-pay-1'),
                            theme_config('vapor-header-pay-2'),
                            theme_config('vapor-header-pay-3'),
                            theme_config('vapor-header-pay-4'),
                            theme_config('vapor-header-pay-5'),
                            theme_config('vapor-header-pay-6')
                        ]|filter(i => i) %}
                        {% if headerPays|length > 0 %}
                            <div class="tp-navbar__pays">
                                {% for img in headerPays %}
                                    <span class="tp-navbar__pay"><img src="{{ img }}" alt="" loading="lazy"></span>
                                {% endfor %}
                            </div>
                        {% endif %}
                    {% endblock %}
                </div>
            </div>
        {% endblock %}
    </div>

    {# Mobil: arama ikonu tıklanınca açılan collapse arama formu #}
    {% block vapor_header_search_collapse %}
        <div class="collapse vapor-search-collapse d-lg-none" id="searchCollapse" data-vapor-search-overlay>
            <div class="vapor-search-collapse__inner">
                <div class="vapor-search-collapse__head">
                    <span class="vapor-search-collapse__title">Wonach suchst du?</span>
                    <button type="button" class="vapor-search-collapse__close" data-vapor-search-close
                            data-bs-toggle="collapse" data-bs-target="#searchCollapse" aria-label="Schließen">✕</button>
                </div>
                {% sw_include '@Storefront/storefront/layout/header/search.html.twig' %}
            </div>
        </div>
    {% endblock %}
{% endblock %}
