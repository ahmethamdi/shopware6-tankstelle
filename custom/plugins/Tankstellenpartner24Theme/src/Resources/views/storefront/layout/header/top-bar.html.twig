{% sw_extends '@Storefront/storefront/layout/header/top-bar.html.twig' %}

{# Vapor: mockup gibi TEK ince bilgi şeridi (gradient banner + sosyal bar birleşik) #}
{% block layout_header_top_bar %}
    {% block vapor_info_bar %}
        {# Texte aus Theme-Config (Admin → Themes → Tankstellenpartner24Theme → Info-Leiste).
           Default-Werte stehen in theme.json (dolu başla). Leeres Feld = ausgeblendet
           (kein |default mehr → Löschen im Panel blendet das Item wirklich aus). #}
        {% set vaporInfobarItems = [
            theme_config('vapor-infobar-1'),
            theme_config('vapor-infobar-2'),
            theme_config('vapor-infobar-3'),
            theme_config('vapor-infobar-4'),
            theme_config('vapor-infobar-5')
        ]|filter(t => t is not empty) %}
        {% if vaporInfobarItems|length %}
            <div class="vapor-info-bar">
                <div class="container">
                    <div class="vapor-info-bar__inner">
                        {% for item in vaporInfobarItems %}
                            <span class="vapor-info-bar__item">{{ item }}</span>
                            {% if not loop.last %}<span class="vapor-info-bar__sep">·</span>{% endif %}
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}
    {% endblock %}
{% endblock %}
