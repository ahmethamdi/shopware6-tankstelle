{% sw_extends '@Storefront/storefront/page/account/profile/recover-password.html.twig' %}

{# =====================================================================
   Tankstellenpartner24Theme — Passwort-Wiederherstellung (forgot password) sayfası:
   login/register (.vapor-auth) ile birebir uyumlu, ortalı tek kart +
   yan bilgi kartı, mavi tema. Native çıplak kart yerine.
   ===================================================================== #}

{% block page_account_profile_recover_password %}
    <div class="account-recover-password vapor-auth vapor-auth--recover">

        {% block page_account_profile_recover_password_inner %}
            <div class="vapor-auth__head">
                <span class="vapor-auth__eyebrow">{% sw_icon 'lock-closed' %} Passwort vergessen?</span>
                <h1 class="vapor-auth__title">{{ 'account.profileRecoverPasswordTitle'|trans|sw_sanitize }}</h1>
                <p class="vapor-auth__sub">Kein Problem — gib deine E-Mail-Adresse ein und wir senden dir einen Link zum Zurücksetzen.</p>
            </div>

            <div class="vapor-auth__grid vapor-auth__grid--recover">

                {# --- SOL: E-Mail formu --- #}
                {% block page_account_profile_recover_password_form %}
                    <form method="post"
                          class="account-recover-password-form card"
                          action="{{ path('frontend.account.recover.request') }}"
                          data-form-handler="true">
                        <div class="card-body">
                            {% block page_account_profile_recover_password_title %}
                                <h2 class="card-title">{{ 'account.profileRecoverPasswordTitle'|trans|sw_sanitize }}</h2>
                            {% endblock %}

                            {% block page_account_profile_recover_password_container %}
                                {% block page_account_profile_recover_password_info %}
                                    <div class="card-text account-recover-password-info login-form-description">
                                        {{ 'account.profileRecoverPasswordInfo'|trans }}
                                    </div>
                                {% endblock %}

                                {% block page_account_profile_recover_password_mail %}
                                    {% sw_include '@Storefront/storefront/component/form/form-input.html.twig' with {
                                        type: 'email',
                                        label: 'account.profileCurrentMail'|trans|sw_sanitize,
                                        id: 'recoverMail',
                                        name: 'email[email]',
                                        autocomplete: 'section-personal email',
                                        violationPath: '/email',
                                        validationRules: 'required,email',
                                    } %}
                                {% endblock %}

                                {% block page_account_profile_recover_password_actions %}
                                    <div class="account-recover-password-form-actions vapor-auth__recover-actions">
                                        {% block page_account_profile_recover_password_action_send %}
                                            <button type="submit"
                                                    class="account-recover-password-submit btn btn-primary login-submit"
                                                    title="{{ 'account.profileRecoverPasswordSubmit'|trans }}">
                                                {{ 'account.profileRecoverPasswordSubmit'|trans }}
                                            </button>
                                        {% endblock %}

                                        {% block page_account_profile_recover_password_action_back %}
                                            <a href="{{ seoUrl('frontend.account.login') }}"
                                               class="account-recover-password-back btn btn-outline-secondary"
                                               title="{{ 'general.back'|trans }}">
                                                {{ 'general.back'|trans }}
                                            </a>
                                        {% endblock %}
                                    </div>
                                {% endblock %}
                            {% endblock %}
                        </div>
                    </form>
                {% endblock %}

                {# --- SAĞ: yardım/bilgi kartı (denge için) --- #}
                <aside class="vapor-auth__adv vapor-auth__adv--recover">
                    <div class="vapor-auth__adv-title">So funktioniert's</div>
                    <ul class="vapor-auth__adv-list">
                        <li><span class="vapor-auth__adv-ico">{% sw_icon 'envelope' %}</span>E-Mail-Adresse eingeben &amp; absenden</li>
                        <li><span class="vapor-auth__adv-ico">{% sw_icon 'lock-closed' %}</span>Link aus der E-Mail anklicken</li>
                        <li><span class="vapor-auth__adv-ico">{% sw_icon 'checkmark' %}</span>Neues Passwort vergeben — fertig</li>
                    </ul>
                    <p class="vapor-auth__recover-help">
                        Keine E-Mail erhalten? Prüfe deinen Spam-Ordner oder kontaktiere unseren B2B-Support.
                    </p>
                </aside>

            </div>
        {% endblock %}
    </div>
{% endblock %}
