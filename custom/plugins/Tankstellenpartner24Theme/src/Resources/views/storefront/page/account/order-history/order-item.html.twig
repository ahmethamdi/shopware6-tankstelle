{% sw_extends '@Storefront/storefront/page/account/order-history/order-item.html.twig' %}

{# =====================================================================
   Tankstellenpartner24Theme — Sipariş kartı:
   1) "Erneut bestellen" (siparişi tekrarla) ⋮ menüden çıkıp BELİRGİN buton.
      Müşteriler en çok kullanacak (B2B tekrar siparişi).
   2) DHL Sendungsverfolgung: teslimatta paket no (trackingCodes) varsa
      nolp.dhl.de takip sayfasına yönlendiren buton (yeni sekme).
      Paket no Plenty → Shopware order_delivery.tracking_codes.
   ⋮ (3 nokta) menüsü kaldırıldı. Tablo verisi SOLDA, butonlar SAĞDA (eski yer),
   alt alta, ikon+isim hizalı.
   ===================================================================== #}

{# ⋮ menüdeki reorder + 3 nokta menü kolonunu KOMPLE kaldır #}
{% block page_account_order_item_context_menu_reorder %}{% endblock %}
{% block page_account_order_item_context_menu_col %}{% endblock %}

{# Aksiyon butonları tablo satırının SAĞ hücresinde (eski yer), alt alta #}
{% block page_account_order_item_order_table_body_cell_toggle_order_details %}
    {% set PRODUCT_LINE_ITEM_TYPE = constant('Shopware\\Core\\Checkout\\Cart\\LineItem\\LineItem::PRODUCT_LINE_ITEM_TYPE') %}

    {# Teslimattaki ilk paket numarası (varsa) #}
    {% set vaporTracking = null %}
    {% if order.primaryOrderDelivery and order.primaryOrderDelivery.trackingCodes|length %}
        {% set vaporTracking = order.primaryOrderDelivery.trackingCodes|first %}
    {% elseif order.deliveries|length and order.deliveries|first.trackingCodes|length %}
        {% set vaporTracking = order.deliveries|first.trackingCodes|first %}
    {% endif %}

    <div class="col-12 col-sm order-item order-item-actions order-table-header-order-table-body-cell vapor-order-actions">
        {# 1) Siparişi tekrarla — belirgin mavi buton (Shopware reorder formu) #}
        <form action="{{ path('frontend.checkout.line-item.add') }}"
              method="post"
              class="vapor-order-reorder-form"
              data-add-to-cart="true">
            <input type="hidden" name="redirectTo" value="frontend.cart.offcanvas">
            {% for lineItem in order.lineItems %}
                {% if lineItem.type == PRODUCT_LINE_ITEM_TYPE %}
                    <input type="hidden" name="lineItems[{{ lineItem.identifier }}][id]" value="{{ lineItem.identifier }}">
                    <input type="hidden" name="lineItems[{{ lineItem.identifier }}][referencedId]" value="{{ lineItem.referencedId }}">
                    <input type="hidden" name="lineItems[{{ lineItem.identifier }}][type]" value="{{ lineItem.type }}">
                    <input type="hidden" name="lineItems[{{ lineItem.identifier }}][stackable]" value="1">
                    <input type="hidden" name="lineItems[{{ lineItem.identifier }}][removable]" value="1">
                    <input type="hidden" name="lineItems[{{ lineItem.identifier }}][quantity]" value="{{ lineItem.quantity }}">
                {% endif %}
            {% endfor %}
            <button type="submit" class="btn btn-primary btn-sm vapor-order-btn vapor-order-btn--reorder">
                {% sw_icon 'bag-product' %}
                <span>{{ 'account.orderContextMenuReorder'|trans|sw_sanitize }}</span>
            </button>
        </form>

        {# 2) DHL Sendungsverfolgung — paket no varsa #}
        {% if vaporTracking %}
            <a href="https://nolp.dhl.de/nextt-online-public/set_identcodes.do?idc={{ vaporTracking|url_encode }}"
               target="_blank" rel="noopener noreferrer"
               class="btn btn-outline-primary btn-sm vapor-order-btn vapor-order-btn--track"
               title="Sendungsverfolgung DHL: {{ vaporTracking }}">
                {% sw_icon 'truck' %}
                <span>Sendung verfolgen</span>
            </a>
        {% endif %}

        {# 3) Detayları göster/gizle #}
        <button class="btn btn-light btn-sm order-hide-btn collapsed vapor-order-btn vapor-order-btn--details"
                data-bs-toggle="collapse"
                data-bs-target="#order{{ order.orderNumber }}"
                aria-expanded="false"
                aria-controls="order{{ order.orderNumber }}">
            {% sw_icon 'eye-open' %}
            <span class="order-hide-btn-text">{{ 'account.orderActionHide'|trans|sw_sanitize }}</span>
            <span class="order-view-btn-text">{{ 'account.orderActionView'|trans|sw_sanitize }}</span>
        </button>
    </div>
{% endblock %}
