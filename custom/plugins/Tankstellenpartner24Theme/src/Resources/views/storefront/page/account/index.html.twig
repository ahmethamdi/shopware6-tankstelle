{% block page_account_overview_welcome %}
    <div class="account-welcome vapor-acc-welcome">
        <span class="vapor-acc-welcome__eyebrow">★ Mein Konto</span>
        <h1 class="vapor-acc-welcome__title">{{ 'account.overviewTitle'|trans|sw_sanitize }}</h1>
        {% block page_account_overview_welcome_intro %}
