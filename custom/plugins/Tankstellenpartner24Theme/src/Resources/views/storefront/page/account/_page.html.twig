{% sw_extends '@Storefront/storefront/page/account/_page.html.twig' %}

{# Tankstellenpartner24Theme — hesap layout:
   - Desktop: sidebar sol kolon (col-xl-3)
   - Mobil: sidebar GİZLİ → üstte "Mein Konto" butonu → alttan açılan bottom-sheet
     (JS initCatSheets data-vapor-sheet mekanizmasını yeniden kullanır) #}

{% block page_account_sidebar %}
    {# VioRepresentativeLogin: Agent (temsilci) modunda context.customer YOK, sadece
       'vioAgent' extension olur. Eskiden koşul sadece customer'a bakıyordu → agent
       girişinde sidebar kolonu HİÇ çizilmiyordu (Vio menüsü col-auto'ya düşüp 0px
       kalıyordu, çakışma + çıkış yok). Artık agent varsa da sidebar wrapper çizilir. #}
    {% set vaporAgent = context.extension('vioAgent') %}
    {% if (context.customer and not context.customer.guest) or vaporAgent %}
        {# Mobil bar avatar/selam: customer varsa ondan, yoksa agent'tan #}
        {% set vaporAva = context.customer ? (context.customer.firstName|first|upper ~ context.customer.lastName|first|upper)
                          : (vaporAgent ? (vaporAgent.firstName|first|upper ~ vaporAgent.lastName|first|upper) : '') %}
        {# MOBİL: üstte tetik butonu (desktop'ta gizli) #}
        <div class="vapor-acc-mobilebar d-lg-none col-12">
            <button type="button" class="vapor-acc-mobilebar__btn" data-vapor-sheet-open="account">
                <span class="vapor-acc-mobilebar__ava">{{ vaporAva }}</span>
                <span class="vapor-acc-mobilebar__txt">
                    <small>{{ 'account.greetings'|trans|sw_sanitize }}</small>
                    <b>{{ 'account.myAccount'|trans|sw_sanitize }}</b>
                </span>
                <span class="vapor-acc-mobilebar__chev">{% sw_icon 'arrow-down' %}</span>
            </button>
        </div>

        {# DESKTOP sidebar + MOBİL bottom-sheet (aynı içerik, CSS ile davranış değişir) #}
        <div class="account-content-aside col-lg-4 col-xl-3 vapor-acc-aside-wrap" data-vapor-sheet="account">
            <div class="vapor-acc-sheet__head d-lg-none">
                <b>{{ 'account.myAccount'|trans|sw_sanitize }}</b>
                <button type="button" class="vapor-acc-sheet__close" data-vapor-sheet-close aria-label="schließen">{% sw_icon 'x' %}</button>
            </div>
            {% sw_include '@Storefront/storefront/page/account/sidebar.html.twig' %}
        </div>

        {# Bottom-sheet backdrop (kategori sayfasıyla ortak JS) #}
        <div class="vapor-sheet__backdrop d-lg-none" data-vapor-sheet-backdrop hidden></div>
    {% endif %}
{% endblock %}

{% block page_account_main %}
    <div class="account-content-main col-lg-8 col-xl-9">
        {% block page_account_main_content %}{% endblock %}
    </div>
{% endblock %}
