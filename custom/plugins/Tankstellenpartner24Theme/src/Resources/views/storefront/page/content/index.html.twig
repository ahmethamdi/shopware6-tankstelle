{% sw_extends '@Storefront/storefront/page/content/index.html.twig' %}

{# Gerçek üründen .vapor-pcard kartı üretir (Bestseller + Neuheiten ortak).
   product = SalesChannelProductEntity, loggedIn = B2B gate, badge = 'Neu'/'Top' vb. #}
{% macro vaporProductCard(product, loggedIn, badge) %}
    {% set pName = product.translated.name ?? product.name %}
    {% set pBrand = product.manufacturer ? (product.manufacturer.translated.name ?? product.manufacturer.name) : '' %}
    {% set pCover = product.cover.media ?? null %}
    {% set pPrice = product.calculatedCheapestPrice ?? product.calculatedPrice %}
    {% set pUrl = path('frontend.detail.page', { productId: product.id }) %}
    <a href="{{ pUrl }}" class="vapor-pcard">
        {% if badge %}<span class="vapor-pcard__badge">{{ badge }}</span>{% endif %}
        <span class="vapor-pcard__age">18+</span>
        <div class="vapor-pcard__img">
            {% if pCover %}
                {% sw_thumbnails 'vapor-pcard-img' with {
                    media: pCover,
                    sizes: { default: '240px' }
                } %}
            {% else %}<svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>{% endif %}
        </div>
        {# NUR echte Bewertungen, keine Fake-Sterne (Wunsch Ahmet/Mike) #}
        {% if product.ratingAverage > 0 %}
            <div class="vapor-pcard__stars">
                {% sw_include '@Storefront/storefront/component/review/rating.html.twig' with { points: product.ratingAverage } %}
            </div>
        {% endif %}
        {% if pBrand %}<div class="vapor-pcard__brand">{{ pBrand }}</div>{% endif %}
        <div class="vapor-pcard__name">{{ pName }}</div>
        <div class="vapor-pcard__foot">
            {% if loggedIn %}
                <span class="vapor-pcard__price">{{ pPrice.unitPrice|currency }}</span>
                <span class="vapor-pcard__add" aria-hidden="true">+</span>
            {% else %}
                <span class="vapor-pcard__price is-login">{% sw_icon 'lock-closed' %} Login</span>
                <span class="vapor-pcard__add is-login" aria-hidden="true">{% sw_icon 'lock-closed' %}</span>
            {% endif %}
        </div>
    </a>
{% endmacro %}

{# =====================================================================
   Tankstellenpartner24Theme — Anasayfa (MOCKUP birebir):
   HERO (köşeli, üstte) → hemen altında 2 kolon:
   SOL = sidebar (HOME + kategoriler) | SAĞ = marka ikonları + promo + bestseller + deals
   Full ekran DEĞİL — container içinde.
   ===================================================================== #}
{% block cms_content %}
    {% set vaporIsHome = shopware.navigation.id == context.salesChannel.navigationCategoryId %}
    {# B2B: Preise für eingeloggte Kunden ODER Vertriebler (Agent).
       Mike-Regel: auch context.extension(vioAgent) prüfen. #}
    {% set vaporLoggedIn = context.customer or context.extension('vioAgent') %}
    {# Dinamik kategori ağacı (subscriber → NavigationLoader). Boşsa Twig fallback ([]). #}
    {% set vaporNavTree = page.extensions.vaporNavTree.tree|default([]) %}

    {% if vaporIsHome %}
        {% set mediaSvg %}<svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>{% endset %}

        {# Anasayfa bölüm görünürlük/sıra ayarları (0) Anasayfa sekmesinden).
           Boş panelde default'lar mevcut düzeni birebir korur. #}
        {% set secHeroShow    = theme_config('vapor-sec-hero-show') %}
        {% set secSidebarShow = theme_config('vapor-sec-sidebar-show') %}

        <div class="vapor-page">
            {# ============ HERO (köşeli, üstte, tam genişlik) ============ #}
            {% if secHeroShow %}
            {% block vapor_home_hero %}
                <section class="vapor-hero">
                    <div class="vapor-hero__content">
                        {% if theme_config('vapor-hero-eyebrow') %}<span class="vapor-hero__eyebrow">{{ theme_config('vapor-hero-eyebrow') }}</span>{% endif %}
                        {% if theme_config('vapor-hero-title') %}<h1 class="vapor-hero__title">{{ theme_config('vapor-hero-title')|raw }}</h1>{% endif %}
                        {% if theme_config('vapor-hero-subtitle') %}<p class="vapor-hero__subtitle">{{ theme_config('vapor-hero-subtitle') }}</p>{% endif %}
                        {% set heroLogo1 = theme_config('vapor-hero-logo-1') %}
                        {% set heroLogo2 = theme_config('vapor-hero-logo-2') %}
                        <div class="vapor-hero__cta-row">
                            {% if theme_config('vapor-hero-cta') %}<a href="{{ theme_config('vapor-hero-cta-link') ?: path('frontend.account.register.page') }}" class="btn vapor-hero__cta">{{ theme_config('vapor-hero-cta') }}</a>{% endif %}
                            {% if heroLogo1 or heroLogo2 %}
                                <div class="vapor-hero__logos">
                                    {% if heroLogo1 %}<img class="vapor-hero__logo" src="{{ heroLogo1 }}" alt="" loading="lazy">{% endif %}
                                    {% if heroLogo2 %}<img class="vapor-hero__logo" src="{{ heroLogo2 }}" alt="" loading="lazy">{% endif %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    {# Mobilde ayrı görsel: panelde "(Mobil)" alanı doluysa telefonda O gösterilir
                       (desktop görseli mobilde gizlenir). Boşsa desktop görseli mobilde de görünür. #}
                    <div class="vapor-hero__media">
                        {% set heroBig      = theme_config('vapor-hero-img-big') %}
                        {% set heroSmall1   = theme_config('vapor-hero-img-small-1') %}
                        {% set heroSmall2   = theme_config('vapor-hero-img-small-2') %}
                        {% set heroBigMob    = theme_config('vapor-hero-img-big-mobile') %}
                        {% set heroSmall1Mob = theme_config('vapor-hero-img-small-1-mobile') %}
                        {% set heroSmall2Mob = theme_config('vapor-hero-img-small-2-mobile') %}
                        {# Görsel linkleri (panelden). Doluysa görsel <a> ile sarılır, boşsa düz div. #}
                        {% set heroBigLink    = theme_config('vapor-hero-img-big-link') %}
                        {% set heroSmall1Link = theme_config('vapor-hero-img-small-1-link') %}
                        {% set heroSmall2Link = theme_config('vapor-hero-img-small-2-link') %}

                        {% set heroBigTag = heroBigLink ? 'a' : 'div' %}
                        <{{ heroBigTag }}{% if heroBigLink %} href="{{ heroBigLink }}"{% endif %} class="vapor-hero__media-big{% if heroBigMob %} has-mobile{% endif %}">
                            {% if heroBig %}<img class="vapor-hero__img vapor-hero__img--desktop" src="{{ heroBig }}" alt="" loading="lazy">{% elseif not heroBigMob %}{{ mediaSvg }}{% endif %}
                            {% if heroBigMob %}<img class="vapor-hero__img vapor-hero__img--mobile" src="{{ heroBigMob }}" alt="" loading="lazy">{% endif %}
                        </{{ heroBigTag }}>
                        {% set heroS1Tag = heroSmall1Link ? 'a' : 'div' %}
                        <{{ heroS1Tag }}{% if heroSmall1Link %} href="{{ heroSmall1Link }}"{% endif %} class="vapor-hero__media-small{% if heroSmall1Mob %} has-mobile{% endif %}">
                            {% if heroSmall1 %}<img class="vapor-hero__img vapor-hero__img--desktop" src="{{ heroSmall1 }}" alt="" loading="lazy">{% elseif not heroSmall1Mob %}{{ mediaSvg }}{% endif %}
                            {% if heroSmall1Mob %}<img class="vapor-hero__img vapor-hero__img--mobile" src="{{ heroSmall1Mob }}" alt="" loading="lazy">{% endif %}
                        </{{ heroS1Tag }}>
                        {% set heroS2Tag = heroSmall2Link ? 'a' : 'div' %}
                        <{{ heroS2Tag }}{% if heroSmall2Link %} href="{{ heroSmall2Link }}"{% endif %} class="vapor-hero__media-small{% if heroSmall2Mob %} has-mobile{% endif %}">
                            {% if heroSmall2 %}<img class="vapor-hero__img vapor-hero__img--desktop" src="{{ heroSmall2 }}" alt="" loading="lazy">{% elseif not heroSmall2Mob %}{{ mediaSvg }}{% endif %}
                            {% if heroSmall2Mob %}<img class="vapor-hero__img vapor-hero__img--mobile" src="{{ heroSmall2Mob }}" alt="" loading="lazy">{% endif %}
                        </{{ heroS2Tag }}>
                    </div>
                </section>
            {% endblock %}
            {% endif %}

            {# ============ 2 KOLON: SOL sidebar | SAĞ içerik ============ #}
            <div class="vapor-body{% if not secSidebarShow %} vapor-body--no-sidebar{% endif %}">
                {# --- SOL: SİDEBAR --- #}
                {% if secSidebarShow %}
                {% block vapor_home_sidebar %}
                    <aside class="vapor-sidebar">
                        <div class="vapor-sidebar__head">Alle Kategorien</div>
                        {% sw_include '@Storefront/storefront/component/vapor/megamenu.html.twig' with { vaporNavTree: vaporNavTree } %}
                        <div class="vapor-sidebar__promo">{% if theme_config('vapor-sidebar-promo-img') %}<img src="{{ theme_config('vapor-sidebar-promo-img') }}" alt="" loading="lazy">{% else %}{{ mediaSvg }}{% endif %}</div>

                        {# Dikey kampanya banner — başlık boşsa tüm CTA gizli #}
                        {% if theme_config('vapor-sidebar-cta-title') or theme_config('vapor-sidebar-cta-btn') %}
                            <a href="{{ path('frontend.account.register.page') }}" class="vapor-sidebar__cta">
                                {% if theme_config('vapor-sidebar-cta-eyebrow') %}<span class="vapor-sidebar__cta-eyebrow">{{ theme_config('vapor-sidebar-cta-eyebrow') }}</span>{% endif %}
                                {% if theme_config('vapor-sidebar-cta-title') %}<span class="vapor-sidebar__cta-title">{{ theme_config('vapor-sidebar-cta-title') }}</span>{% endif %}
                                {% if theme_config('vapor-sidebar-cta-btn') %}<span class="vapor-sidebar__cta-btn">{{ theme_config('vapor-sidebar-cta-btn') }}</span>{% endif %}
                            </a>
                        {% endif %}

                        {# USP listesi — başlığı boş olan madde gizli; hepsi boşsa liste gizli #}
                        {% set vaporUsps = [] %}
                        {% for u in [
                            { i: 'truck', t: theme_config('vapor-usp-1-title'), s: theme_config('vapor-usp-1-sub') },
                            { i: 'lock-closed', t: theme_config('vapor-usp-2-title'), s: theme_config('vapor-usp-2-sub') },
                            { i: 'arrow-circle-left', t: theme_config('vapor-usp-3-title'), s: theme_config('vapor-usp-3-sub') },
                            { i: 'headset', t: theme_config('vapor-usp-4-title'), s: theme_config('vapor-usp-4-sub') }
                        ] %}
                            {% if u.t %}{% set vaporUsps = vaporUsps|merge([u]) %}{% endif %}
                        {% endfor %}
                        {% if vaporUsps|length %}
                            <ul class="vapor-sidebar__usp">
                                {% for usp in vaporUsps %}
                                    <li class="vapor-sidebar__usp-item">
                                        <span class="vapor-sidebar__usp-ico">{% sw_icon usp.i %}</span>
                                        <span class="vapor-sidebar__usp-txt">
                                            <b>{{ usp.t }}</b>
                                            {% if usp.s %}<small>{{ usp.s }}</small>{% endif %}
                                        </span>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    </aside>
                {% endblock %}
                {% endif %}

                {# --- SAĞ: marka ikonları + promo + bestseller + deals ---
                   SIRALAMA SİSTEMİ: her blok aşağıda {% set X_html %}...{% endset %}
                   ile HTML'e render edilir, sonra vaporSections listesine
                   {order, show, html} olarak eklenir; en sonda order'a göre
                   sıralanıp show=true olanlar basılır. Serbest section'lar (0b)
                   da aynı listeye girer → ekip panelden sıra no + göster/gizle ile
                   tüm bölümleri (mevcut + serbest) birlikte diziler. #}
                <div class="vapor-body__main">
                    {# ---- YENİ: Pill şeridi (yuvarlak-ikonlu kategori kısayolları) ----
                       Canlı kategori ağacından (vaporNavTree) ilk seviye kategoriler.
                       Panelden manuel de doldurulabilir (vapor-pill-1..10-name/-link/-icon). #}
                    {% set vaporSecHtml_pills %}
                    {% block vapor_home_pills %}
                        {% set vaporManualPills = [] %}
                        {% for i in 1..10 %}
                            {% set pName = theme_config('vapor-pill-' ~ i ~ '-name') %}
                            {% if pName %}
                                {% set vaporManualPills = vaporManualPills|merge([{
                                    name: pName,
                                    link: theme_config('vapor-pill-' ~ i ~ '-link'),
                                    icon: theme_config('vapor-pill-' ~ i ~ '-icon')
                                }]) %}
                            {% endif %}
                        {% endfor %}
                        <div class="vapor-pills" data-vapor-dragscroll>
                            <div class="vapor-pills__track">
                                {% if vaporManualPills|length > 0 %}
                                    {% for p in vaporManualPills %}
                                        <a href="{{ p.link ?: '#' }}" class="vapor-pill">
                                            <span class="vapor-pill__ico">
                                                {% if p.icon %}<img src="{{ p.icon }}" alt="" loading="lazy">{% else %}{% sw_icon 'tags' %}{% endif %}
                                            </span>
                                            <span class="vapor-pill__name">{{ p.name }}</span>
                                        </a>
                                    {% endfor %}
                                {% else %}
                                    {# Fallback: canlı kategori ağacı ilk seviye #}
                                    {% for m in vaporNavTree|slice(0, 10) %}
                                        <a href="{{ seoUrl('frontend.navigation.page', { navigationId: m.category.id }) }}" class="vapor-pill">
                                            <span class="vapor-pill__ico">{% sw_icon 'tags' %}</span>
                                            <span class="vapor-pill__name">{{ m.category.translated.name }}</span>
                                        </a>
                                    {% endfor %}
                                {% endif %}
                            </div>
                        </div>
                    {% endblock %}
                    {% endset %}
                    {% set vaporSecHtml_brands %}
                    {% block vapor_home_brands %}
                        <div class="vapor-brandnav" data-vapor-dragscroll>
                            <div class="vapor-brandnav__track">
                                {# 16 marka slotu config'ten: isim + logo + link. İsim boşsa gizli. Logo varsa img, yoksa baş harfler. #}
                                {% for i in 1..16 %}
                                    {% set bName = theme_config('vapor-brand-' ~ i ~ '-name') %}
                                    {% set bLogo = theme_config('vapor-brand-' ~ i ~ '-logo') %}
                                    {% set bLink = theme_config('vapor-brand-' ~ i ~ '-link') %}
                                    {% if bName %}
                                        <a href="{{ bLink ?: '#' }}" class="vapor-brandnav__item">
                                            <span class="vapor-brandnav__circle">
                                                {% if bLogo %}<img src="{{ bLogo }}" alt="{{ bName }}" loading="lazy">{% else %}{{ bName|split(' ')|map(w => w|first)|join('')|slice(0,2)|upper }}{% endif %}
                                            </span>
                                            <span class="vapor-brandnav__name">{{ bName }}</span>
                                        </a>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endblock %}

                    {% endset %}

                    {# ---- YENİ: Bento grid (1 büyük + 2 orta + 2 küçük) + 6 kısayol kart ----
                       Tüm içerik panelden: vapor-bento-{big,mid1,mid2,sm1,sm2}-{img,title,sub,link}
                       + vapor-bento-short-1..6-{name,link,icon}. Boş kartlar gizli. #}
                    {% set vaporSecHtml_bento %}
                    {% block vapor_home_bento %}
                        {% set bentoSlots = [
                            { k: 'big',  cls: 'is-big'  },
                            { k: 'mid1', cls: 'is-mid'  },
                            { k: 'sm1',  cls: 'is-sm'   },
                            { k: 'mid2', cls: 'is-mid2' },
                            { k: 'sm2',  cls: 'is-sm2'  }
                        ] %}
                        {% set bentoAny = false %}
                        {% for s in bentoSlots %}
                            {% if theme_config('vapor-bento-' ~ s.k ~ '-title') or theme_config('vapor-bento-' ~ s.k ~ '-img') %}{% set bentoAny = true %}{% endif %}
                        {% endfor %}
                        {# Kısayol kartları #}
                        {% set bentoShorts = [] %}
                        {% for i in 1..6 %}
                            {% set snName = theme_config('vapor-bento-short-' ~ i ~ '-name') %}
                            {% if snName %}
                                {% set bentoShorts = bentoShorts|merge([{ name: snName, link: theme_config('vapor-bento-short-' ~ i ~ '-link'), icon: theme_config('vapor-bento-short-' ~ i ~ '-icon') }]) %}
                            {% endif %}
                        {% endfor %}

                        {% if bentoAny or bentoShorts|length > 0 %}
                            {% if bentoAny %}
                                <div class="vapor-bento">
                                    {% for s in bentoSlots %}
                                        {% set bImg   = theme_config('vapor-bento-' ~ s.k ~ '-img') %}
                                        {% set bTitle = theme_config('vapor-bento-' ~ s.k ~ '-title') %}
                                        {% set bSub   = theme_config('vapor-bento-' ~ s.k ~ '-sub') %}
                                        {% set bLink  = theme_config('vapor-bento-' ~ s.k ~ '-link') %}
                                        {% set bTag   = bLink ? 'a' : 'div' %}
                                        <{{ bTag }} class="vapor-bento__cell {{ s.cls }}"{% if bLink %} href="{{ bLink }}"{% endif %}>
                                            {% if bImg %}<img class="vapor-bento__img" src="{{ bImg }}" alt="{{ bTitle }}" loading="lazy">{% else %}<span class="vapor-bento__ph">{{ mediaSvg }}</span>{% endif %}
                                            {% if bSub or bTitle %}
                                                <div class="vapor-bento__body">
                                                    {% if bSub %}<span class="vapor-bento__eyebrow">{{ bSub }}</span>{% endif %}
                                                    {% if bTitle %}<span class="vapor-bento__title">{{ bTitle }}</span>{% endif %}
                                                    {% if bLink %}<span class="vapor-bento__cta">Entdecken →</span>{% endif %}
                                                </div>
                                            {% endif %}
                                        </{{ bTag }}>
                                    {% endfor %}
                                </div>
                            {% endif %}
                            {% if bentoShorts|length > 0 %}
                                {# Marka kısayolları (kategori pill şeridiyle tekrar ETMESİN diye
                                   ayrı başlık + marka baş-harfi rozeti). Logo yüklenirse img kullanılır. #}
                                {% set bentoShortsTitle = theme_config('vapor-bento-shorts-title') ?: 'Top-Marken' %}
                                <div class="vapor-section-head vapor-shortcuts-head">
                                    <h2 class="vapor-section-head__title">{{ bentoShortsTitle }}</h2>
                                </div>
                                <div class="vapor-shortcuts">
                                    {% for sc in bentoShorts %}
                                        <a href="{{ sc.link ?: '#' }}" class="vapor-shortcut vapor-shortcut--brand">
                                            <span class="vapor-shortcut__ico">{% if sc.icon %}<img src="{{ sc.icon }}" alt="{{ sc.name }}" loading="lazy">{% else %}<b class="vapor-shortcut__initials">{{ sc.name|split(' ')|map(w => w|first)|join('')|slice(0, 2)|upper }}</b>{% endif %}</span>
                                            <span class="vapor-shortcut__name">{{ sc.name }}</span>
                                            <span class="vapor-shortcut__arrow" aria-hidden="true">›</span>
                                        </a>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        {% endif %}
                    {% endblock %}
                    {% endset %}

                    {# ---- YENİ: Kategori slider ("Kategoriye Göre Alışveriş") ----
                       Canlı kategori ağacından her ana kategori bir kart:
                       büyük görsel + 3 küçük görsel (mozaik) + isim + ürün sayısı + İncele.
                       Görseller: kategorinin media'sı ya da alt kategorilerin media'sı; yoksa placeholder. #}
                    {% set vaporSecHtml_catslider %}
                    {% block vapor_home_catslider %}
                        {% set catTitle = theme_config('vapor-catslider-title') ?: 'Nach Kategorie einkaufen' %}
                        {% if vaporNavTree|length > 0 %}
                            <div class="vapor-section-head">
                                <h2 class="vapor-section-head__title">{{ catTitle }}</h2>
                                <div class="vapor-slider-nav">
                                    <button type="button" class="vapor-slider-btn" data-vapor-slide="catslider" data-dir="prev" aria-label="zurück">{% sw_icon 'chevron-left' %}</button>
                                    <button type="button" class="vapor-slider-btn" data-vapor-slide="catslider" data-dir="next" aria-label="weiter">{% sw_icon 'chevron-right' %}</button>
                                </div>
                            </div>
                            <div class="vapor-catslider" data-vapor-slider="catslider" data-vapor-dragscroll>
                                <div class="vapor-catslider__track">
                                    {% for m in vaporNavTree %}
                                        {% set cat = m.category %}
                                        {% set catUrl = seoUrl('frontend.navigation.page', { navigationId: cat.id }) %}
                                        {% set kids = m.children|default([]) %}
                                        {% set mainMedia = cat.media ?? null %}
                                        <a href="{{ catUrl }}" class="vapor-catcard">
                                            <div class="vapor-catcard__media">
                                                <span class="vapor-catcard__big">
                                                    {% if mainMedia %}{% sw_thumbnails 'vapor-catcard-big' with { media: mainMedia, sizes: { default: '260px' } } %}{% else %}{{ mediaSvg }}{% endif %}
                                                </span>
                                                <span class="vapor-catcard__mini">
                                                    {% for k in kids|slice(0, 3) %}
                                                        <span class="vapor-catcard__minicell">
                                                            {% if k.category.media %}{% sw_thumbnails 'vapor-catcard-mini' with { media: k.category.media, sizes: { default: '90px' } } %}{% else %}{{ mediaSvg }}{% endif %}
                                                        </span>
                                                    {% else %}
                                                        <span class="vapor-catcard__minicell">{{ mediaSvg }}</span>
                                                        <span class="vapor-catcard__minicell">{{ mediaSvg }}</span>
                                                        <span class="vapor-catcard__minicell">{{ mediaSvg }}</span>
                                                    {% endfor %}
                                                </span>
                                            </div>
                                            <div class="vapor-catcard__foot">
                                                <div class="vapor-catcard__info">
                                                    <span class="vapor-catcard__name">{{ cat.translated.name }}</span>
                                                    {% if kids|length > 0 %}<span class="vapor-catcard__count">{{ kids|length }} Kategorien</span>{% endif %}
                                                </div>
                                                <span class="vapor-catcard__btn">Ansehen</span>
                                            </div>
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    {% endblock %}
                    {% endset %}

                    {# ---- YENİ (Bölüm 4): SOL büyük lacivert promo kart + SAĞ 2 ürün slider ----
                       Sol kart: panelden eyebrow/başlık/metin/buton + opsiyonel arka plan görseli
                       (görsel boşsa lacivert gradient zemin). Sağ: Neuheiten ürünlerinden yatay
                       kayan mini slider (aynı .vapor-pcard makrosu, B2B login-gate korunur). #}
                    {% set vaporSecHtml_promoduo %}
                    {% block vapor_home_promoduo %}
                        {% set pdEyebrow = theme_config('vapor-promoduo-eyebrow') %}
                        {% set pdTitle   = theme_config('vapor-promoduo-title') %}
                        {% set pdText    = theme_config('vapor-promoduo-text') %}
                        {% set pdBtn     = theme_config('vapor-promoduo-btn') %}
                        {% set pdLink    = theme_config('vapor-promoduo-link') %}
                        {% set pdBg      = theme_config('vapor-promoduo-bg') %}
                        {% set pdRightTitle = theme_config('vapor-promoduo-right-title') %}
                        {% set pdProducts = page.extensions.vaporNeu.products ?? [] %}
                        {% if pdTitle or pdEyebrow or pdBg or pdProducts|length %}
                            <div class="vapor-promoduo">
                                {# --- SOL: büyük promo kart --- #}
                                {% set pdCardTag = pdLink ? 'a' : 'div' %}
                                <{{ pdCardTag }} class="vapor-promoduo__card{% if pdBg %} has-bg{% endif %}"{% if pdLink %} href="{{ pdLink }}"{% endif %}>
                                    {% if pdBg %}<img class="vapor-promoduo__bg" src="{{ pdBg }}" alt="" loading="lazy">{% endif %}
                                    <div class="vapor-promoduo__card-body">
                                        {% if pdEyebrow %}<span class="vapor-promoduo__eyebrow">{{ pdEyebrow }}</span>{% endif %}
                                        {% if pdTitle %}<h2 class="vapor-promoduo__title">{{ pdTitle|raw }}</h2>{% endif %}
                                        {% if pdText %}<p class="vapor-promoduo__text">{{ pdText }}</p>{% endif %}
                                        {% if pdBtn %}<span class="vapor-promoduo__btn">{{ pdBtn }} <span aria-hidden="true">→</span></span>{% endif %}
                                    </div>
                                </{{ pdCardTag }}>

                                {# --- SAĞ: 2'li ürün slider (Neuheiten) --- #}
                                <div class="vapor-promoduo__products">
                                    <div class="vapor-section-head vapor-promoduo__head">
                                        {% if pdRightTitle %}<h3 class="vapor-section-head__title">{{ pdRightTitle }}</h3>{% endif %}
                                        <div class="vapor-slider-nav">
                                            <button type="button" class="vapor-slider-btn" data-vapor-slide="promoduo" data-dir="prev" aria-label="zurück">{% sw_icon 'chevron-left' %}</button>
                                            <button type="button" class="vapor-slider-btn" data-vapor-slide="promoduo" data-dir="next" aria-label="weiter">{% sw_icon 'chevron-right' %}</button>
                                        </div>
                                    </div>
                                    <div class="vapor-promoduo__slider" data-vapor-slider="promoduo" data-vapor-dragscroll>
                                        <div class="vapor-promoduo__track">
                                            {% for product in pdProducts %}
                                                {{ _self.vaporProductCard(product, vaporLoggedIn, 'Neu') }}
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endblock %}
                    {% endset %}
                    {% set vaporSecHtml_campaign %}
                    {% block vapor_home_campaign %}
                        {# Üst tam genişlik (col-12) görsel banner — promo görselleriyle
                           aynı yükseklikte (16/3 = tek promo'nun 8/3'ünün 2 katı geniş).
                           Görsel boşsa gizli. Mobilde ayrı görsel varsa o gösterilir. #}
                        {% set ctbImg    = theme_config('vapor-campaign-top-img') %}
                        {% set ctbImgMob = theme_config('vapor-campaign-top-img-mobile') %}
                        {% set ctbLink   = theme_config('vapor-campaign-top-link') %}
                        {% if ctbImg or ctbImgMob %}
                            {% set ctbTag = ctbLink ? 'a' : 'div' %}
                            <{{ ctbTag }} class="vapor-campaign-top{% if ctbImgMob %} has-mobile{% endif %}"{% if ctbLink %} href="{{ ctbLink }}"{% endif %}>
                                {% if ctbImg %}<img class="vapor-campaign-top__img vapor-campaign-top__img--desktop" src="{{ ctbImg }}" alt="" loading="lazy">{% endif %}
                                {% if ctbImgMob %}<img class="vapor-campaign-top__img vapor-campaign-top__img--mobile" src="{{ ctbImgMob }}" alt="" loading="lazy">{% endif %}
                            </{{ ctbTag }}>
                        {% endif %}
                        {# Marke veya Text boşsa dar metin-banner gizli #}
                        {% if theme_config('vapor-campaign-brand') or theme_config('vapor-campaign-text') %}
                            <a href="{{ theme_config('vapor-campaign-link') ?: '#' }}" class="vapor-campaign">
                                {% if theme_config('vapor-campaign-brand') %}<span class="vapor-campaign__brand">{{ theme_config('vapor-campaign-brand') }}</span>{% endif %}
                                {% if theme_config('vapor-campaign-text') %}<span class="vapor-campaign__text">{{ theme_config('vapor-campaign-text') }}</span>{% endif %}
                            </a>
                        {% endif %}
                    {% endblock %}

                    {% endset %}
                    {% set vaporSecHtml_promo %}
                    {% block vapor_home_promo_imgs %}
                        <div class="vapor-promo-imgs">
                            {% set promo1Link = theme_config('vapor-promo-img-1-link') %}
                            {% set promo2Link = theme_config('vapor-promo-img-2-link') %}
                            {% set promo1Tag = promo1Link ? 'a' : 'div' %}
                            {% set promo2Tag = promo2Link ? 'a' : 'div' %}
                            <{{ promo1Tag }}{% if promo1Link %} href="{{ promo1Link }}"{% endif %} class="vapor-promo-img">{% if theme_config('vapor-promo-img-1') %}<img src="{{ theme_config('vapor-promo-img-1') }}" alt="" loading="lazy">{% else %}{{ mediaSvg }}{% endif %}</{{ promo1Tag }}>
                            <{{ promo2Tag }}{% if promo2Link %} href="{{ promo2Link }}"{% endif %} class="vapor-promo-img">{% if theme_config('vapor-promo-img-2') %}<img src="{{ theme_config('vapor-promo-img-2') }}" alt="" loading="lazy">{% else %}{{ mediaSvg }}{% endif %}</{{ promo2Tag }}>
                        </div>
                    {% endblock %}

                    {# ============ Kategori vitrini (görsel kartlar) ============ #}
                    {% endset %}
                    {% set vaporSecHtml_categories %}
                    {% block vapor_home_categories %}
                        {# Panelden hiç kategori adı girilmiş mi? Girildiyse config kullan; girilmediyse
                           canlı navigasyondan (vaporNavTree) otomatik doldur (hardcoded ID YOK). #}
                        {% set vaporCatConfigUsed = false %}
                        {% for i in 1..16 %}{% if theme_config('vapor-cat-' ~ i ~ '-name') %}{% set vaporCatConfigUsed = true %}{% endif %}{% endfor %}
                        <div class="vapor-section-head">
                            <h2 class="vapor-section-head__title">Kategorien</h2>
                        </div>
                        <div class="vapor-cattiles">
                            {% if vaporCatConfigUsed %}
                                {# Panel kullanıldı: 16 slot config'ten. İsim boşsa kart gizli. Link boşsa dinamik ağaçtan eşleşen URL. #}
                                {% for i in 1..16 %}
                                    {% set catName = theme_config('vapor-cat-' ~ i ~ '-name') %}
                                    {% set catImg = theme_config('vapor-cat-img-' ~ i) %}
                                    {% set catLink = theme_config('vapor-cat-' ~ i ~ '-link') %}
                                    {% set defItem = vaporNavTree[i - 1]|default(null) %}
                                    {% set catHref = catLink ?: (defItem ? (defItem.category.seoUrl ?: seoUrl('frontend.navigation.page', { navigationId: defItem.category.id })) : '#') %}
                                    {% if catName %}
                                        <a class="vapor-cattile" href="{{ catHref }}">
                                            <span class="vapor-cattile__img">{% if catImg %}<img src="{{ catImg }}" alt="{{ catName }}" loading="lazy">{% else %}{{ mediaSvg }}{% endif %}</span>
                                            <span class="vapor-cattile__name">{{ catName }}</span>
                                        </a>
                                    {% endif %}
                                {% endfor %}
                            {% else %}
                                {# Panel boş: canlı navigasyon kategorileri (gerçek isim + SEO URL). #}
                                {% for treeItem in vaporNavTree %}
                                    {% set cat = treeItem.category %}
                                    {% set catHref = cat.type == 'folder' ? '#' : (cat.seoUrl ?: seoUrl('frontend.navigation.page', { navigationId: cat.id })) %}
                                    <a class="vapor-cattile" href="{{ catHref }}">
                                        <span class="vapor-cattile__img">{% if cat.media %}<img src="{{ cat.media.url }}" alt="{{ cat.translated.name }}" loading="lazy">{% else %}{{ mediaSvg }}{% endif %}</span>
                                        <span class="vapor-cattile__name">{{ cat.translated.name }}</span>
                                    </a>
                                {% endfor %}
                            {% endif %}
                        </div>
                    {% endblock %}

                    {% endset %}
                    {% set vaporSecHtml_deals %}
                    {% block vapor_home_deals %}
                        {% set dealTextColor = theme_config('vapor-deal-text-color') %}
                        <div class="vapor-section-head">
                            {% if theme_config('vapor-deals-title') %}<h2 class="vapor-section-head__title">{{ theme_config('vapor-deals-title') }}</h2>{% endif %}
                        </div>
                        <div class="vapor-deals-row">
                            {# 3 Deal config'ten: name/brand/price/img/link/hours. İsim boşsa gizli. #}
                            {% for i in 1..3 %}
                                {% set dName = theme_config('vapor-deal-' ~ i ~ '-name') %}
                                {% set dBrand = theme_config('vapor-deal-' ~ i ~ '-brand') %}
                                {% set dPrice = theme_config('vapor-deal-' ~ i ~ '-price') %}
                                {% set dImg = theme_config('vapor-deal-' ~ i ~ '-img') %}
                                {% set dLink = theme_config('vapor-deal-' ~ i ~ '-link') %}
                                {% set dHours = theme_config('vapor-deal-' ~ i ~ '-hours')|default(12 + i * 6) %}
                                {% if dName %}
                                <div class="vapor-deal" data-vapor-countdown data-end-hours="{{ dHours }}">
                                    {# Flip-clock geri sayım #}
                                    <div class="vapor-deal__timer">
                                        <span class="vapor-deal__t"><b data-d>05</b><small>Tage</small></span>
                                        <span class="vapor-deal__t"><b data-h>14</b><small>Stunden</small></span>
                                        <span class="vapor-deal__t"><b data-m>26</b><small>Minuten</small></span>
                                        <span class="vapor-deal__t"><b data-s>24</b><small>Sekunden</small></span>
                                    </div>
                                    {# Beyaz iç ürün kartı #}
                                    <div class="vapor-deal__card">
                                        <div class="vapor-deal__img">{% if dImg %}<img src="{{ dImg }}" alt="{{ dName }}" loading="lazy">{% else %}{{ mediaSvg }}{% endif %}</div>
                                        <div class="vapor-deal__brand"{% if dealTextColor %} style="background:{{ dealTextColor }}"{% endif %}>{{ dBrand }}</div>
                                        <div class="vapor-deal__name"{% if dealTextColor %} style="color:{{ dealTextColor }}"{% endif %}>{{ dName }}</div>
                                        {# Deal-Karte = reine Panel-Texte (kein echtes Produkt) → KEINE Fake-Sterne/Reviews.
                                           Bewertungen nur dort, wo echte Shopware-Daten existieren (Produktdetail/Listing). #}
                                        <div class="vapor-deal__foot">
                                            {% if vaporLoggedIn %}
                                                <span class="vapor-deal__price">{{ dPrice }}</span>
                                                <a href="{{ dLink ?: '#' }}" class="vapor-deal__btn">
                                                    {% sw_icon 'bag-product' %} Kaufen
                                                </a>
                                            {% else %}
                                                <span class="vapor-deal__price is-login">{% sw_icon 'lock-closed' %} Login</span>
                                                <a href="{{ path('frontend.account.login.page') }}" class="vapor-deal__btn">Anmelden</a>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endblock %}

                    {# ============ Geniş banner (Deals ↔ Neuheiten arası,
                       ~1292×239) — panelden görsel+link, görsel boşsa gizli ============ #}
                    {% endset %}
                    {% set vaporSecHtml_banner %}
                    {% block vapor_home_banner %}
                        {% set vbImg    = theme_config('vapor-home-banner-img') %}
                        {% set vbImgMob = theme_config('vapor-home-banner-img-mobile') %}
                        {% set vbLink   = theme_config('vapor-home-banner-link') %}
                        {% if vbImg or vbImgMob %}
                            {% set vbTag = vbLink ? 'a' : 'div' %}
                            <{{ vbTag }} class="vapor-home-banner{% if vbImgMob %} has-mobile{% endif %}"{% if vbLink %} href="{{ vbLink }}"{% endif %}>
                                {% if vbImg %}<img class="vapor-home-banner__img vapor-home-banner__img--desktop" src="{{ vbImg }}" alt="" loading="lazy">{% endif %}
                                {% if vbImgMob %}<img class="vapor-home-banner__img vapor-home-banner__img--mobile" src="{{ vbImgMob }}" alt="" loading="lazy">{% endif %}
                            </{{ vbTag }}>
                        {% endif %}
                    {% endblock %}

                    {# ============ Neuheiten — yatay slider kart ============ #}
                    {% endset %}
                    {% set vaporSecHtml_neu %}
                    {% block vapor_home_neu %}
                        <div class="vapor-section-head">
                            {% if theme_config('vapor-neu-title') %}<h2 class="vapor-section-head__title">{{ theme_config('vapor-neu-title') }}</h2>{% endif %}
                            <div class="vapor-slider-nav">
                                <button type="button" class="vapor-slider-btn" data-slide="prev" aria-label="Zurück"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"/></svg></button>
                                <button type="button" class="vapor-slider-btn" data-slide="next" aria-label="Weiter"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></button>
                            </div>
                        </div>
                        {% set vaporNeu = page.extensions.vaporNeu.products ?? [] %}
                        <div class="vapor-cardslider" data-vapor-cardslider>
                            <div class="vapor-cardslider__track">
                                {% for product in vaporNeu %}
                                    {{ _self.vaporProductCard(product, vaporLoggedIn, 'Neu') }}
                                {% endfor %}
                            </div>
                        </div>
                    {% endblock %}

                    {# ============ Vitrine-Banner (Neuheiten ↔ Bestseller arası):
                       görsel solda + başlık/metin/buton sağda, hepsi panelden.
                       Görsel boşsa tüm blok gizli ============ #}
                    {% endset %}
                    {% set vaporSecHtml_showcase %}
                    {% block vapor_home_showcase %}
                        {% set scImg      = theme_config('vapor-showcase-img') %}
                        {% set scImgMob   = theme_config('vapor-showcase-img-mobile') %}
                        {% set scTitleImg = theme_config('vapor-showcase-title-img') %}
                        {% set scTitle    = theme_config('vapor-showcase-title') %}
                        {% set scText     = theme_config('vapor-showcase-text') %}
                        {% set scNote     = theme_config('vapor-showcase-note') %}
                        {% set scBtnTxt   = theme_config('vapor-showcase-btn-text') %}
                        {% set scBtnLnk   = theme_config('vapor-showcase-btn-link') %}
                        {% set scBtn2Txt  = theme_config('vapor-showcase-btn2-text') %}
                        {% set scBtn2Lnk  = theme_config('vapor-showcase-btn2-link') %}
                        {% if scImg or scImgMob %}
                            <div class="vapor-showcase{% if scImgMob %} has-mobile{% endif %}">
                                <div class="vapor-showcase__media">
                                    {% if scImg %}<img class="vapor-showcase__img vapor-showcase__img--desktop" src="{{ scImg }}" alt="{{ scTitle }}" loading="lazy">{% endif %}
                                    {% if scImgMob %}<img class="vapor-showcase__img vapor-showcase__img--mobile" src="{{ scImgMob }}" alt="{{ scTitle }}" loading="lazy">{% endif %}
                                </div>
                                <div class="vapor-showcase__body">
                                    {% if scTitleImg %}
                                        <img class="vapor-showcase__title-img" src="{{ scTitleImg }}" alt="{{ scTitle }}" loading="lazy">
                                    {% elseif scTitle %}
                                        <h3 class="vapor-showcase__title">{{ scTitle }}</h3>
                                    {% endif %}
                                    {% if scText %}<p class="vapor-showcase__text">{{ scText }}</p>{% endif %}
                                    {% if (scBtnTxt and scBtnLnk) or (scBtn2Txt and scBtn2Lnk) %}
                                        <div class="vapor-showcase__btns">
                                            {% if scBtnTxt and scBtnLnk %}
                                                <a href="{{ scBtnLnk }}" class="vapor-showcase__btn">{{ scBtnTxt }}</a>
                                            {% endif %}
                                            {% if scBtn2Txt and scBtn2Lnk %}
                                                <a href="{{ scBtn2Lnk }}" class="vapor-showcase__btn vapor-showcase__btn--outline">{{ scBtn2Txt }}</a>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                    {% if scNote %}<p class="vapor-showcase__note">{{ scNote }}</p>{% endif %}
                                </div>
                            </div>
                        {% endif %}
                    {% endblock %}

                    {# ============ Bestseller — EN ALTTA (kullanıcı sırası: Kategorien →
                       Deals → Banner → Neuheiten → Vitrine → Bestseller) ============ #}
                    {% endset %}
                    {% set vaporSecHtml_bestseller %}
                    {% block vapor_home_section_title %}
                        {% set vaporBest = page.extensions.vaporBestseller.products ?? [] %}
                        <div class="vapor-section-head">
                            {% if theme_config('vapor-bestseller-title') %}<h2 class="vapor-section-head__title">{{ theme_config('vapor-bestseller-title') }}</h2>{% endif %}
                            <a href="{{ path('frontend.navigation.page', { navigationId: context.salesChannel.navigationCategoryId }) }}" class="vapor-section-head__link">Alle anzeigen →</a>
                        </div>
                        {% if vaporBest|length %}
                            <div class="vapor-cardgrid">
                                {% for product in vaporBest %}
                                    {{ _self.vaporProductCard(product, vaporLoggedIn, 'Bestseller') }}
                                {% endfor %}
                            </div>
                        {% else %}
                            {# Fallback: Bestseller ürünü yoksa boş bırak.
                               (Vapor'da burada {{ parent() }} ile CMS listing çağrılıyordu,
                               ama bu blok artık {% set %} capture içinde → parent() çağrılamaz.
                               Bestseller ürünleri atandığında bu dal zaten dolacak.) #}
                        {% endif %}
                    {% endblock %}

                    {# ============ Marka logo slider (kayan şerit) ============ #}
                    {% endset %}
                    {% set vaporSecHtml_topmarken %}
                    {% block vapor_home_brand_slider %}
                        {# AYRI config: Top-Marken-Leiste bloğu (vapor-topmarke-*). Hero altı markadan bağımsız — buraya ürün/logo görseli koyabilirsin. #}
                        {% set vaporTopList = [] %}
                        {% for i in 1..12 %}
                            {% set tLogo = theme_config('vapor-topmarke-' ~ i ~ '-logo') %}
                            {% set tName = theme_config('vapor-topmarke-' ~ i ~ '-name') %}
                            {# Logo VEYA isim varsa göster; ikisi de boşsa gizli #}
                            {% if tLogo or tName %}{% set vaporTopList = vaporTopList|merge([{ name: tName, logo: tLogo, link: theme_config('vapor-topmarke-' ~ i ~ '-link') }]) %}{% endif %}
                        {% endfor %}
                        {% if vaporTopList|length %}
                            <div class="vapor-section-head vapor-brandslider-head">
                                <h2 class="vapor-section-head__title">Top-Marken</h2>
                            </div>
                            <div class="vapor-brandslider">
                                <div class="vapor-brandslider__track">
                                    {% for brand in vaporTopList|merge(vaporTopList) %}
                                        <a href="{{ brand.link ?: '#' }}" class="vapor-brandslider__item">
                                            {% if brand.logo %}<img src="{{ brand.logo }}" alt="{{ brand.name }}" loading="lazy">{% else %}{{ brand.name|upper }}{% endif %}
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    {% endblock %}

                    {# ============ B2B avantaj / kayıt CTA banner ============ #}
                    {% endset %}
                    {% set vaporSecHtml_b2b %}
                    {% block vapor_home_b2b_cta %}
                        {# Statları topla (sayı boş olanı atla) #}
                        {% set vaporB2bStats = [] %}
                        {% for s in [
                            {n: theme_config('vapor-b2b-stat-1-n'), l: theme_config('vapor-b2b-stat-1-l')},
                            {n: theme_config('vapor-b2b-stat-2-n'), l: theme_config('vapor-b2b-stat-2-l')},
                            {n: theme_config('vapor-b2b-stat-3-n'), l: theme_config('vapor-b2b-stat-3-l')},
                            {n: theme_config('vapor-b2b-stat-4-n'), l: theme_config('vapor-b2b-stat-4-l')}
                        ] %}
                            {% if s.n %}{% set vaporB2bStats = vaporB2bStats|merge([s]) %}{% endif %}
                        {% endfor %}
                        {% set vaporB2bHasContent = theme_config('vapor-b2b-eyebrow') or theme_config('vapor-b2b-title') or theme_config('vapor-b2b-text') or theme_config('vapor-b2b-btn-primary') or theme_config('vapor-b2b-btn-ghost') %}

                        {# Tüm B2B banner boşsa (içerik + stat yok) hiç gösterme #}
                        {% if vaporB2bHasContent or vaporB2bStats|length %}
                            <section class="vapor-b2b">
                                <div class="vapor-b2b__content">
                                    {% if theme_config('vapor-b2b-eyebrow') %}<span class="vapor-b2b__eyebrow">{{ theme_config('vapor-b2b-eyebrow') }}</span>{% endif %}
                                    {% if theme_config('vapor-b2b-title') %}<h2 class="vapor-b2b__title">{{ theme_config('vapor-b2b-title')|raw }}</h2>{% endif %}
                                    {% if theme_config('vapor-b2b-text') %}<p class="vapor-b2b__text">{{ theme_config('vapor-b2b-text') }}</p>{% endif %}
                                    {% if theme_config('vapor-b2b-btn-primary') or theme_config('vapor-b2b-btn-ghost') %}
                                        <div class="vapor-b2b__actions">
                                            {% if theme_config('vapor-b2b-btn-primary') %}<a href="{{ path('frontend.account.register.page') }}" class="vapor-b2b__btn is-primary">{{ theme_config('vapor-b2b-btn-primary') }}</a>{% endif %}
                                            {% if theme_config('vapor-b2b-btn-ghost') %}<a href="{{ path('frontend.account.login.page') }}" class="vapor-b2b__btn is-ghost">{{ theme_config('vapor-b2b-btn-ghost') }}</a>{% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                                {% if vaporB2bStats|length %}
                                    <div class="vapor-b2b__stats">
                                        {% for s in vaporB2bStats %}
                                            <div class="vapor-b2b__stat"><b>{{ s.n }}</b>{% if s.l %}<small>{{ s.l }}</small>{% endif %}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </section>
                        {% endif %}
                    {% endblock %}
                    {% endset %}

                    {# ---- SIRALAMA LİSTESİ: {order, html} — mevcut bloklar + serbest section'lar
                       order'a göre sıralanıp basılır. show/order theme_config'ten;
                       default'lar (theme.json) mevcut düzeni birebir korur. #}
                    {% set vaporSections = [] %}
                    {% set vaporSecDefs = [
                        { key: 'pills',      def: 5,   html: vaporSecHtml_pills },
                        { key: 'brands',     def: 10,  html: vaporSecHtml_brands },
                        { key: 'bento',      def: 15,  html: vaporSecHtml_bento },
                        { key: 'catslider',  def: 18,  html: vaporSecHtml_catslider },
                        { key: 'promoduo',   def: 19,  html: vaporSecHtml_promoduo },
                        { key: 'campaign',   def: 20,  html: vaporSecHtml_campaign },
                        { key: 'promo',      def: 30,  html: vaporSecHtml_promo },
                        { key: 'categories', def: 40,  html: vaporSecHtml_categories },
                        { key: 'deals',      def: 50,  html: vaporSecHtml_deals },
                        { key: 'banner',     def: 60,  html: vaporSecHtml_banner },
                        { key: 'neu',        def: 70,  html: vaporSecHtml_neu },
                        { key: 'showcase',   def: 80,  html: vaporSecHtml_showcase },
                        { key: 'bestseller', def: 90,  html: vaporSecHtml_bestseller },
                        { key: 'topmarken',  def: 100, html: vaporSecHtml_topmarken },
                        { key: 'b2b',        def: 110, html: vaporSecHtml_b2b }
                    ] %}
                    {% for s in vaporSecDefs %}
                        {% set sShow = theme_config('vapor-sec-' ~ s.key ~ '-show') %}
                        {% set sOrderRaw = theme_config('vapor-sec-' ~ s.key ~ '-order') %}
                        {% set sOrder = (sOrderRaw is not empty ? sOrderRaw : s.def)|round %}
                        {% if sShow %}
                            {% set vaporSections = vaporSections|merge([{ order: sOrder, html: s.html }]) %}
                        {% endif %}
                    {% endfor %}

                    {# ---- SERBEST SECTION'LAR (0b sekmesi): 1-4 kolon, kolon başına
                       görsel+başlık+metin+link, opsiyonel mobil yatay scroll.
                       show=true VE en az bir kolon/başlık doluysa listeye eklenir. #}
                    {% for n in 1..4 %}
                        {% if theme_config('vapor-free-' ~ n ~ '-show') %}
                            {% set fCols = (theme_config('vapor-free-' ~ n ~ '-cols') ?: 2)|round %}
                            {% if fCols < 1 %}{% set fCols = 1 %}{% elseif fCols > 4 %}{% set fCols = 4 %}{% endif %}
                            {% set fTitle  = theme_config('vapor-free-' ~ n ~ '-title') %}
                            {% set fScroll = theme_config('vapor-free-' ~ n ~ '-scroll') %}
                            {% set fColData = [] %}
                            {% for c in 1..fCols %}
                                {% set fColData = fColData|merge([{
                                    img:   theme_config('vapor-free-' ~ n ~ '-c' ~ c ~ '-img'),
                                    title: theme_config('vapor-free-' ~ n ~ '-c' ~ c ~ '-title'),
                                    text:  theme_config('vapor-free-' ~ n ~ '-c' ~ c ~ '-text'),
                                    link:  theme_config('vapor-free-' ~ n ~ '-c' ~ c ~ '-link')
                                }]) %}
                            {% endfor %}
                            {% set fHasContent = fTitle ? true : false %}
                            {% for cd in fColData %}{% if cd.img or cd.title or cd.text %}{% set fHasContent = true %}{% endif %}{% endfor %}
                            {% if fHasContent %}
                                {% set fOrderRaw = theme_config('vapor-free-' ~ n ~ '-order') %}
                                {% set fOrder = (fOrderRaw is not empty ? fOrderRaw : (40 + n * 20))|round %}
                                {% set fBody %}
                                    <div class="vapor-free">
                                        {% if fTitle %}<div class="vapor-section-head"><h2 class="vapor-section-head__title">{{ fTitle }}</h2></div>{% endif %}
                                        <div class="vapor-free__grid vapor-free__grid--{{ fCols }}{% if fScroll %} vapor-free__grid--scroll{% endif %}">
                                            {% for cd in fColData %}
                                                {% set cellTag = cd.link ? 'a' : 'div' %}
                                                <{{ cellTag }} class="vapor-free__cell"{% if cd.link %} href="{{ cd.link }}"{% endif %}>
                                                    {% if cd.img %}<span class="vapor-free__img"><img src="{{ cd.img }}" alt="{{ cd.title }}" loading="lazy"></span>{% endif %}
                                                    {% if cd.title %}<span class="vapor-free__title">{{ cd.title }}</span>{% endif %}
                                                    {% if cd.text %}<span class="vapor-free__text">{{ cd.text }}</span>{% endif %}
                                                </{{ cellTag }}>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endset %}
                                {% set vaporSections = vaporSections|merge([{ order: fOrder, html: fBody }]) %}
                            {% endif %}
                        {% endif %}
                    {% endfor %}

                    {# order'a göre sırala ve bas #}
                    {% for sec in vaporSections|sort((a, b) => a.order <=> b.order) %}
                        {{ sec.html|raw }}
                    {% endfor %}
                </div>
            </div>
        </div>
    {% elseif (page.landingPage ? page.landingPage.cmsPage.type : page.cmsPage.type)|default('') != 'product_list' %}
        {# ============ İÇERİK SAYFASI (AGB/Datenschutz/Impressum/Widerruf vb.) —
           ürün listesi DEĞİL (cmsPage.type != product_list). Kategori ağacı/filtre YOK.
           Temiz, ortalanmış, okunur tipografi. ============ #}
        {% set vaporCmsPage = page.landingPage ? page.landingPage.cmsPage : page.cmsPage %}
        {% set vaporContentTitle = page.header.navigation.active.translated.name
            |default(page.landingPage.translated.name)
            |default(page.metaInformation.metaTitle)
            |default('') %}
        <div class="vapor-content-page">
            <article class="vapor-content-page__inner">
                {% if vaporContentTitle %}
                    <header class="vapor-content-page__head">
                        <h1 class="vapor-content-page__title">{{ vaporContentTitle }}</h1>
                    </header>
                {% endif %}
                <div class="vapor-content-page__cms">
                    {{ parent() }}
                </div>
            </article>
        </div>
    {% else %}
        {# ============ KATEGORİ SAYFASI — 2 kolon (sol: kategori ağacı + filtreler | sağ: başlık + liste) ============ #}
        {# Dinamik kategori ağacı (subscriber → NavigationLoader). #}
        {% set vaporNavTree = page.extensions.vaporNavTree.tree|default([]) %}

        {# Sayfa başlığı: önce aktif navigasyon, yoksa dinamik ağaçtan eşleştir. #}
        {% set vaporCatTitle = page.header.navigation.active.translated.name|default('') %}
        {% if vaporCatTitle is empty %}
            {% for treeItem in vaporNavTree %}
                {% if shopware.navigation.id == treeItem.category.id %}{% set vaporCatTitle = treeItem.category.translated.name %}{% endif %}
            {% endfor %}
        {% endif %}

        <div class="vapor-cat">
            {# --- SOL KOL: kategori paneli + filtreler tek sticky blok (desktop'ta birlikte kayar) ---
                 Mobilde aside ve filtersheet position:fixed bottom-sheet olur → sarmalayıcı etkisiz. #}
            <div class="vapor-cat__col">
                {# --- kategori ağacı sidebar (mega menü) --- #}
                <aside class="vapor-cat__aside" data-vapor-sheet="cats">
                    <div class="vapor-cat__aside-head">
                        Alle Kategorien
                        <button type="button" class="vapor-sheet__close" data-vapor-sheet-close aria-label="Schließen">✕</button>
                    </div>
                    {% sw_include '@Storefront/storefront/component/vapor/megamenu.html.twig' with { vaporNavTree: vaporNavTree, activeId: shopware.navigation.id } %}
                </aside>

                {# --- Filtreler için ayrı BOTTOM-SHEET (data-vapor-sheet="filter") --- #}
                <div class="vapor-cat__filtersheet" data-vapor-sheet="filter">
                    <div class="vapor-cat__aside-head">
                        Filter
                        <button type="button" class="vapor-sheet__close" data-vapor-sheet-close aria-label="Schließen">✕</button>
                    </div>
                    {# Filtre paneli JS ile buraya taşınır (CSS desktop'ta sol kola koyar) #}
                    <div class="vapor-cat__filterslot" data-vapor-filter-slot></div>
                </div>
            </div>

            {# Bottom-sheet'ler için ortak backdrop #}
            <div class="vapor-sheet__backdrop" data-vapor-sheet-backdrop hidden></div>

            {# --- SAĞ: başlık + CMS içeriği (filtre paneli + ürün listesi) --- #}
            <div class="vapor-cat__main">
                <h1 class="vapor-cat__title">{{ vaporCatTitle ?: page.header.navigation.active.translated.name|default(page.metaInformation.metaTitle|default('Produkte')) }}</h1>

                {# MOBİL: yan yana 2 buton — Kategorien + Filter (bottom-sheet açar) #}
                <div class="vapor-cat__mobilebar">
                    <button type="button" class="vapor-cat__mbtn" data-vapor-sheet-open="cats">
                        {% sw_icon 'stack' %}<span>Kategorien</span>
                    </button>
                    <button type="button" class="vapor-cat__mbtn" data-vapor-sheet-open="filter">
                        {% sw_icon 'filter' %}<span>Filter</span>
                    </button>
                </div>

                <div class="vapor-cat__cms">
                    {{ parent() }}
                </div>
            </div>
        </div>

        {# =====================================================================
           B2B CANLI SEPET BARI (sticky, ekran altı) — +/− satırlardan sepete
           anında yazar; bu bar GERÇEK sepet özetini gösterir. JS: initLiveCart.
           ===================================================================== #}
        <div class="vapor-bulkbar" data-vapor-cartbar hidden>
            <div class="vapor-bulkbar__inner">
                <div class="vapor-bulkbar__info">
                    <span class="vapor-bulkbar__count"><b data-cart-products>0</b> Produkte</span>
                    <span class="vapor-bulkbar__sep">·</span>
                    <span class="vapor-bulkbar__qty"><b data-cart-units>0</b> Stück</span>
                    <span class="vapor-bulkbar__total" data-cart-total></span>
                </div>
                <div class="vapor-bulkbar__actions">
                    <a class="vapor-bulkbar__clear" href="{{ path('frontend.checkout.cart.page') }}">Warenkorb ansehen</a>
                    <a class="vapor-bulkbar__submit" href="{{ path('frontend.checkout.confirm.page') }}">
                        {% sw_icon 'bag-product' %} <span>Zur Kasse</span>
                    </a>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
